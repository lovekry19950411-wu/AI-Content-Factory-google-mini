# AI Video Studio Environment Configuration

# 1. AI Engine (Google Gemini)
# 獲取地址: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Video Rendering Service (Optional)
# 用於串接 Luma / Runway / Pika 等影片生成 API
VITE_VIDEO_PROVIDER_KEY=

# 3. Text-to-Speech (Optional)
# 用於高品質 AI 配音串接
VITE_TTS_PROVIDER_KEY=

# 4. Storage & DB (Optional)
# 用於持久化存儲內容庫
VITE_DATABASE_URL=
